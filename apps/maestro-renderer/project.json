{
    "name": "maestro-renderer",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "prefix": "app",
    "sourceRoot": "apps/maestro-renderer/src",
    "cli": {
        "cache": {
            "enabled": false
        }
    },
    "tags": [],
    "targets": {
        "build": {
            "executor": "@angular/build:application",
            "dependsOn": ["design-tokens-check"],
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/apps/maestro-renderer",
                "browser": "apps/maestro-renderer/src/main.ts",
                "polyfills": ["zone.js"],
                "tsConfig": "apps/maestro-renderer/tsconfig.app.json",
                "assets": [
                    {
                        "glob": "**/*",
                        "input": "apps/maestro-renderer/src/assets"
                    }
                ],
                "styles": ["apps/maestro-renderer/src/styles.css"]
            },
            "configurations": {
                "production": {
                    "baseHref": "./",
                    "fileReplacements": [
                        {
                            "replace": "apps/maestro-renderer/src/environments/environment.ts",
                            "with": "apps/maestro-renderer/src/environments/environment.prod.ts"
                        },
                        {
                            "replace": "apps/maestro-renderer/src/app/app.routes.ts",
                            "with": "apps/maestro-renderer/src/app/app.routes.prod.ts"
                        }
                    ],
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "500kb",
                            "maximumError": "1mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "4kb",
                            "maximumError": "8kb"
                        }
                    ],
                    "outputHashing": "all"
                },
                "development": {
                    "optimization": false,
                    "extractLicenses": false,
                    "sourceMap": true
                }
            },
            "defaultConfiguration": "production"
        },
        "serve": {
            "continuous": true,
            "executor": "@angular/build:dev-server",
            "configurations": {
                "production": {
                    "buildTarget": "maestro-renderer:build:production"
                },
                "development": {
                    "buildTarget": "maestro-renderer:build:development"
                }
            },
            "defaultConfiguration": "development",
            "options": {
                "proxyConfig": "apps/maestro-renderer/proxy.conf.json"
            }
        },
        "extract-i18n": {
            "executor": "@angular/build:extract-i18n",
            "options": {
                "buildTarget": "maestro-renderer:build"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "dependsOn": ["design-tokens-check"],
            "options": {
                "lintFilePatterns": [
                    "apps/maestro-renderer/tailwind.config.js",
                    "apps/maestro-renderer/src/**/*.ts",
                    "apps/maestro-renderer/src/**/*.html"
                ]
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "dependsOn": ["design-tokens-check"],
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "apps/maestro-renderer/jest.config.ts",
                "tsConfig": "apps/maestro-renderer/tsconfig.spec.json"
            }
        },
        "design-tokens-generate": {
            "executor": "nx:run-commands",
            "options": {
                "command": "node apps/maestro-renderer/tools/design-tokens.cjs generate"
            }
        },
        "design-tokens-watch": {
            "executor": "nx:run-commands",
            "continuous": true,
            "options": {
                "command": "node apps/maestro-renderer/tools/design-tokens.cjs watch"
            }
        },
        "design-tokens-check": {
            "executor": "nx:run-commands",
            "dependsOn": ["design-tokens-test"],
            "options": {
                "command": "node apps/maestro-renderer/tools/design-tokens.cjs check"
            }
        },
        "design-tokens-test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "node --test apps/maestro-renderer/tools/design-tokens.node-test.cjs"
            }
        },
        "serve-static": {
            "continuous": true,
            "executor": "@nx/web:file-server",
            "options": {
                "buildTarget": "maestro-renderer:build",
                "port": 4200,
                "staticFilePath": "dist/apps/maestro-renderer/browser",
                "spa": true
            }
        }
    }
}
