{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "rootDir": "../..",
        "types": ["node"]
    },
    "exclude": ["**/*.spec.ts", "**/*.test.ts", "jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"],
    "include": ["**/*.ts"],
    "angularCompilerOptions": {
        "extendedDiagnostics": {
            "checks": {
                "nullishCoalescingNotNullable": "suppress",
                "optionalChainNotNullable": "suppress"
            }
        }
    }
}
