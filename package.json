{
    "name": "release-maestro",
    "productName": "Release Maestro",
    "version": "1.0.0",
    "main": "dist/out-tsc/app/main.js",
    "private": true,
    "scripts": {
        "postinstall": "electron-builder install-app-deps",
        "rebuild": "electron-rebuild",
        "ng": "ng",
        "dev": "npm-run-all -p electron:serve:watch ng:serve",
        "ng:serve": "ng serve -c web",
        "build": "npm run shared:build && npm run electron:serve-tsc && ng build --base-href ./",
        "build:dev": "npm run build -- -c dev",
        "build:prod": "npm run build -- -c production",
        "web:build": "npm run build -- -c web-production",
        "shared:build": "tsc -p shared/tsconfig.json",
        "shared:rewrite-imports": "node scripts/rewrite-imports.js",
        "electron": "electron",
        "electron:serve-tsc": "tsc -p tsconfig.serve.json",
        "electron:serve": "wait-on tcp:4200 && npm run shared:build && npm run electron:serve-tsc && electron . --serve",
        "electron:serve:watch": "npx nodemon -w ./app -w ./shared -e .ts -x 'npm run electron:serve'",
        "electron:local": "npm run build:dev && electron .",
        "electron:build": "npm run build:prod && npm run shared:build && npm run electron:serve-tsc && npm run shared:rewrite-imports && electron-builder build --publish=never",
        "test": "ng test --watch=false",
        "test:watch": "ng test",
        "e2e": "npm run build:prod && playwright test -c e2e/playwright.config.ts e2e/",
        "e2e:show-trace": "playwright show-trace e2e/tracing/trace.zip",
        "version": "conventional-changelog -i CHANGELOG.md -s -r 0 && git add CHANGELOG.md",
        "lint": "ng lint",
        "format": "prettier --write \"./**/*.ts\" \"./**/*.html\" \"./**/*.css\" \"./**/*.json\"",
        "format:check": "prettier --check \"./**/*.ts\" \"./**/*.html\" \"./**/*.css\" \"./**/*.json\""
    },
    "dependencies": {
        "@angular/cdk": "^20.1.3",
        "@angular/common": "20.1.3",
        "@angular/compiler": "20.1.3",
        "@angular/core": "20.1.3",
        "@angular/forms": "20.1.3",
        "@angular/language-service": "20.1.3",
        "@angular/platform-browser": "20.1.3",
        "@angular/platform-browser-dynamic": "20.1.3",
        "@angular/router": "20.1.3",
        "@floating-ui/dom": "^1.6.0",
        "@ng-icons/core": "32.1.0",
        "@ng-icons/octicons": "32.1.0",
        "@tailwindcss/container-queries": "0.1.1",
        "bandcamp-fetch": "2.0.0",
        "better-sqlite3": "12.2.0",
        "conf": "14.0.0",
        "drizzle-orm": "0.44.3",
        "ng-primitives": "0.67.0",
        "rxjs": "7.8.1",
        "tslib": "2.6.2",
        "zod": "4.0.10",
        "zone.js": "0.15.1"
    },
    "devDependencies": {
        "@angular-builders/custom-webpack": "20.0.0",
        "@angular-builders/jest": "20.0.0",
        "@angular-eslint/builder": "20.1.1",
        "@angular-eslint/eslint-plugin": "20.1.1",
        "@angular-eslint/eslint-plugin-template": "20.1.1",
        "@angular-eslint/schematics": "20.1.1",
        "@angular-eslint/template-parser": "20.1.1",
        "@angular/build": "^20.1.3",
        "@angular/cli": "20.1.3",
        "@angular/compiler-cli": "20.1.3",
        "@ngx-translate/core": "16.0.4",
        "@ngx-translate/http-loader": "16.0.1",
        "@playwright/test": "1.52.0",
        "@types/better-sqlite3": "7.6.13",
        "@types/jest": "29.5.14",
        "@types/node": "22.15.29",
        "@typescript-eslint/eslint-plugin": "^8.33.1",
        "@typescript-eslint/parser": "^8.33.1",
        "autoprefixer": "10.4.21",
        "conventional-changelog-cli": "4.1.0",
        "drizzle-kit": "0.31.4",
        "electron": "36.4.0",
        "electron-builder": "26.0.12",
        "electron-debug": "4.1.0",
        "electron-reloader": "1.2.3",
        "eslint": "^9.28.0",
        "eslint-plugin-import": "2.31.0",
        "eslint-plugin-jsdoc": "50.7.1",
        "eslint-plugin-prefer-arrow": "1.2.3",
        "jest": "29.7.0",
        "node-polyfill-webpack-plugin": "4.1.0",
        "npm-run-all": "4.1.5",
        "playwright": "1.52.0",
        "postcss": "8.5.6",
        "prettier": "3.5.3",
        "tailwindcss": "4.1.13",
        "ts-node": "10.9.2",
        "typescript": "5.8.3",
        "wait-on": "7.2.0",
        "webdriver-manager": "12.1.9"
    },
    "engines": {
        "node": ">= 22.12.0 >= 24.0.0",
        "typescript": ">= 5.8.0 < 5.9.0"
    },
    "browserslist": [
        "chrome 136"
    ]
}
