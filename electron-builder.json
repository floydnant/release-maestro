{
    "asar": true,
    "directories": {
        "output": "release/"
    },
    "files": [
        "package.json",
        "node_modules/**/*",
        "!node_modules/**/*.ts",
        "!node_modules/**/*.map",
        {
            "from": "dist/apps/maestro-electron",
            "to": ".",
            "filter": ["**/*", "!**/*.map"]
        },
        {
            "from": "dist/apps/maestro-renderer/browser",
            "to": "maestro-renderer",
            "filter": ["**/*"]
        }
    ],
    "extraFiles": [
        {
            "from": "drizzle",
            "to": "drizzle",
            "filter": ["**/*"]
        },
        {
            "from": "LICENSE.md",
            "to": "LICENSE.md"
        },
        {
            "from": "THIRD_PARTY_NOTICES.txt",
            "to": "THIRD_PARTY_NOTICES.txt"
        }
    ],
    "publish": {
        "provider": "github",
        "owner": "floydnant",
        "repo": "release-maestro"
    },
    "win": {
        "icon": "dist/assets/icons/favicon.ico",
        "target": [
            {
                "target": "nsis",
                "arch": ["x64"]
            }
        ]
    },
    "portable": {
        "splashImage": "dist/assets/icons/electron.bmp"
    },
    "mac": {
        "icon": "dist/assets/icons/favicon.icns",
        "target": [
            {
                "target": "default",
                "arch": ["universal"]
            }
        ],
        "extraFiles": [
            {
                "from": "apple-scripts",
                "filter": ["**/*"],
                "to": "apple-scripts"
            }
        ]
    },
    "linux": {
        "icon": "dist/assets/icons/favicon.512x512.png",
        "target": ["AppImage"]
    }
}
