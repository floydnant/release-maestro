{
    "asar": true,
    "directories": {
        "output": "release/"
    },
    "files": [
        "**/*",
        "!**/*.ts",
        "!**/*.map",
        "!package-lock.json",
        {
            "from": "../dist",
            "filter": ["**/*"]
        },
        {
            "from": "../dist/out-tsc/app",
            "to": ".",
            "filter": ["**/*.js"]
        },
        {
            "from": "../dist/out-tsc/src",
            "to": ".",
            "filter": ["**/*.js"]
        }
    ],
    "extraFiles": [
        {
            "from": "drizzle",
            "to": "drizzle",
            "filter": ["**/*"]
        }
    ],
    "win": {
        "icon": "dist/assets/icons",
        "target": ["portable"]
    },
    "portable": {
        "splashImage": "dist/assets/icons/electron.bmp"
    },
    "mac": {
        "icon": "dist/assets/icons",
        "target": ["dmg"],
        "extraFiles": [
            {
                "from": "apple-scripts",
                "filter": ["**/*"],
                "to": "apple-scripts"
            }
        ]
    },
    "linux": {
        "icon": "dist/assets/icons",
        "target": ["AppImage"]
    }
}
