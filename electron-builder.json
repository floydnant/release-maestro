{
    "asar": true,
    "directories": {
        "output": "release/"
    },
    "extraMetadata": {
        "main": "index.js"
    },
    "files": ["!package.json"],
    "extraFiles": [
        {
            "from": "drizzle",
            "to": "drizzle",
            "filter": ["**/*"]
        },
        {
            "from": "apps/metadata-engine/target/release",
            "to": "metadata-engine",
            "filter": ["metadata-engine", "metadata-engine.exe"]
        },
        {
            "from": "LICENSE.md",
            "to": "LICENSE.md"
        },
        {
            "from": "THIRD_PARTY_NOTICES.txt",
            "to": "THIRD_PARTY_NOTICES.txt"
        }
    ],
    "publish": {
        "provider": "github",
        "owner": "floydnant",
        "repo": "release-maestro"
    },
    "win": {
        "icon": "dist/assets/icons/favicon.ico",
        "target": [
            {
                "target": "nsis",
                "arch": ["x64"]
            }
        ]
    },
    "portable": {
        "splashImage": "dist/assets/icons/electron.bmp"
    },
    "mac": {
        "icon": "dist/assets/icons/favicon.icns",
        "x64ArchFiles": "**/metadata-engine",
        "target": [
            {
                "target": "default",
                "arch": ["universal"]
            }
        ],
        "extraFiles": [
            {
                "from": "apple-scripts",
                "filter": ["**/*"],
                "to": "apple-scripts"
            }
        ]
    },
    "linux": {
        "icon": "dist/assets/icons/favicon.512x512.png",
        "target": ["AppImage"]
    }
}
